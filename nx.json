{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "main",
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "sharedGlobals": ["{workspaceRoot}/mapping.json", "{workspaceRoot}/mapping-interop.json"]
    },
    "targetDefaults": {
        "build": { "cache": true },
        "generate": { "cache": true },
        "lint": { "cache": true },
        "figma:sync": { "cache": false },
        "figma:export-icons": { "cache": false }
    },
    "release": {
        "projects": ["packages/*"],
        "releaseTagPattern": "{version}",
        "git": {
            "commitMessage": "chore(release): bump version to {version} w/ changelog"
        },
        "changelog": {
            "projectChangelogs": {
                "createRelease": "github"
            }
        },
        "version": {
            "conventionalCommits": true
        }
    }
}
