{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "main",
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "sharedGlobals": ["{workspaceRoot}/mapping.json", "{workspaceRoot}/mapping-interop.json"]
    },
    "targetDefaults": {
        "build": { "cache": true },
        "generate": { "cache": true },
        "lint": { "cache": true },
        "figma:sync": { "cache": false },
        "figma:export-icons": { "cache": false }
    },
    "release": {
        "git": {
            "commitMessage": "chore(release): bump version {version} w/ changelog",
            "tagSign": true
        },
        "changelog": {
            "workspaceChangelog": {
                "createRelease": "github"
            },
            "projectChangelogs": false
        },
        "projects": ["@koobiq/icons", "@koobiq/angular-icons", "@koobiq/react-icons", "@koobiq/visuals"],
        "projectsRelationship": "fixed",
        "releaseTagPattern": "{version}"
    }
}
