{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "main",
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "sharedGlobals": ["{workspaceRoot}/mapping.json", "{workspaceRoot}/mapping-interop.json"]
    },
    "targetDefaults": {
        "build": { "cache": true },
        "generate": { "cache": true },
        "lint": { "cache": true },
        "figma:sync": { "cache": false },
        "figma:export-icons": { "cache": false }
    },
    "release": {
        "git": {
            "commitMessage": "chore(release): bump version w/ changelog"
        },
        "groups": {
            "icons": {
                "projects": ["@koobiq/icons", "@koobiq/angular-icons", "@koobiq/react-icons"],
                "projectsRelationship": "fixed",
                "releaseTagPattern": "{version}",
                "version": { "conventionalCommits": true },
                "changelog": { "createRelease": "github" }
            },
            "visuals": {
                "projects": ["@koobiq/visuals"],
                "projectsRelationship": "independent",
                "releaseTagPattern": "{projectName}@{version}",
                "version": { "conventionalCommits": true },
                "changelog": { "createRelease": "github" }
            }
        }
    }
}
