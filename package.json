{
    "name": "@koobiq/icons-workspace",
    "version": "11.5.0",
    "description": "",
    "private": true,
    "license": "MIT",
    "packageManager": "yarn@4.1.1",
    "workspaces": [
        "packages/*"
    ],
    "keywords": [
        "design-system",
        "koobiq",
        "fonts",
        "icons",
        "symbols"
    ],
    "scripts": {
        "prepare": "husky",
        "clean": "rimraf temp && rimraf packages/icons/dist",
        "check-mapping": "node packages/icons/scripts/check-mapping.mjs",
        "------RELEASE SCRIPTS------": "------------------------------------------------------------------------------",
        "stage:commit": "koobiq-cli stage-commit -c \"Icons\" --without-references",
        "publish:gitlab": "koobiq-cli publish-ci-gitlab",
        "publish:github": "koobiq-cli publish-ci-github",
        "------FIGMA SCRIPTS------": "--------------------------------------------------------------------------------",
        "figma:export-icons": "nx run @koobiq/icons:figma:export-icons",
        "figma:sync": "yarn run clean && nx run @koobiq/icons:figma:sync",
        "------BUILD SCRIPTS------": "--------------------------------------------------------------------------------",
        "build:icons": "nx run @koobiq/icons:build",
        "build": "nx run-many -t build",
        "-----CI-----": "---------------------------------------------------------------------------------------------",
        "prettier": "prettier --check . --ignore-unknown",
        "prettier:fix": "yarn run prettier --write",
        "eslint": "eslint . --ext='.js,.mjs'",
        "eslint:fix": "yarn run eslint --fix"
    },
    "release": {
        "packages": [
            "icons"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@figma-export/cli": "^6.4.0",
        "@figma-export/output-components-as-svg": "^6.4.0",
        "@figma-export/output-components-as-svgr": "^6.4.0",
        "@figma-export/transform-svg-with-svgo": "^6.4.0",
        "@koobiq/cli": "^18.39.2",
        "@nx/angular": "^20.8.4",
        "@nx/react": "^20.8.4",
        "@svgr/plugin-jsx": "^8.1.0",
        "@svgr/plugin-prettier": "^8.1.0",
        "@svgr/plugin-svgo": "^8.1.0",
        "@types/eslint": "^8.56.12",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^24.10.4",
        "cross-env": "^7.0.3",
        "dotenv": "^16.6.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-prettier": "^5.5.6",
        "fantasticon": "^3.0.0",
        "fs-extra": "^11.3.4",
        "husky": "^9.1.7",
        "inquirer": "^10.2.2",
        "json-schema-to-typescript": "^15.0.4",
        "lint-staged": "^15.5.2",
        "npm-run-all": "^4.1.5",
        "nx": "^20.8.4",
        "prettier": "^3.8.3",
        "rimraf": "^5.0.10",
        "svg-sprite": "^2.0.4",
        "svgo": "^3.3.3",
        "ts-node": "^10.9.2",
        "typescript": "~5.5.4"
    }
}
