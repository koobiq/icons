{
    "name": "@koobiq/icons-workspace",
    "version": "11.5.0",
    "description": "",
    "private": true,
    "license": "MIT",
    "packageManager": "yarn@4.1.1",
    "workspaces": [
        "packages/*"
    ],
    "keywords": [
        "design-system",
        "koobiq",
        "fonts",
        "icons",
        "symbols"
    ],
    "scripts": {
        "prepare": "husky",
        "clean": "yarn cache clean && nx reset && rimraf temp && rimraf -g packages/**/{dist,node_modules}",
        "check-mapping": "node packages/icons/scripts/check-mapping.mjs",
        "------RELEASE SCRIPTS------": "------------------------------------------------------------------------------",
        "release": "nx release --skip-publish",
        "publish": "nx release publish",
        "------FIGMA SCRIPTS------": "--------------------------------------------------------------------------------",
        "figma:export-icons": "nx run @koobiq/icons:figma:export-icons",
        "figma:sync": "yarn run clean && nx run @koobiq/icons:figma:sync",
        "------BUILD SCRIPTS------": "--------------------------------------------------------------------------------",
        "build:icons": "nx run @koobiq/icons:build",
        "build": "nx run-many -t build",
        "-----CI-----": "---------------------------------------------------------------------------------------------",
        "prettier": "prettier --check . --ignore-unknown",
        "prettier:fix": "yarn run prettier --write",
        "lint": "nx run-many -t lint",
        "lint:fix": "nx run-many -t lint -- --fix"
    },
    "release": {
        "packages": [
            "icons"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@figma-export/cli": "^6.4.0",
        "@figma-export/output-components-as-svg": "^6.4.0",
        "@figma-export/output-components-as-svgr": "^6.4.0",
        "@figma-export/transform-svg-with-svgo": "^6.4.0",
        "@nx/angular": "^20.8.4",
        "@nx/eslint": "^20.8.4",
        "@nx/react": "^20.8.4",
        "@nx/vite": "^20.8.4",
        "@types/eslint": "^8.56.12",
        "@types/node": "^24.10.4",
        "@typescript-eslint/eslint-plugin": "^7",
        "@typescript-eslint/parser": "^7",
        "@vitejs/plugin-react": "^5.0.0",
        "cross-env": "^7.0.3",
        "dotenv": "^16.6.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-prettier": "^5.5.6",
        "fantasticon": "^3.0.0",
        "fs-extra": "^11.3.4",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "nx": "^20.8.4",
        "prettier": "^3.8.3",
        "rimraf": "^5.0.10",
        "typescript": "~5.5.4"
    }
}
