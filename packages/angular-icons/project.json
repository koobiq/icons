{
    "name": "@koobiq/angular-icons",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "generate": {
            "executor": "nx:run-commands",
            "dependsOn": [
                {
                    "projects": ["@koobiq/icons"],
                    "target": "figma:sync"
                }
            ],
            "options": {
                "command": "npx ts-node scripts/generate.ts",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{workspaceRoot}/packages/icons/svg/**/*.svg"],
            "outputs": ["{projectRoot}/icons", "{projectRoot}/public-api.ts"]
        },
        "build": {
            "executor": "@nx/angular:library",
            "dependsOn": ["generate"],
            "options": {
                "project": "packages/angular-icons/ng-package.json"
            },
            "outputs": ["{projectRoot}/dist"]
        }
    }
}
