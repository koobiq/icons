{
    "name": "@koobiq/angular-icons",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "generate": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx ts-node scripts/generate.ts",
                "cwd": "{projectRoot}",
                "assets": ["{workspaceRoot}/packages/icons/svg/**/*.svg"]
            },
            "inputs": ["{workspaceRoot}/packages/icons/svg/**/*.svg"],
            "outputs": ["{projectRoot}/icons", "{projectRoot}/public-api.ts"]
        },
        "build": {
            "executor": "@nx/angular:package",
            "dependsOn": ["generate"],
            "options": {
                "project": "{projectRoot}/ng-package.json"
            },
            "outputs": ["{projectRoot}/dist"]
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "options": {
                "eslintConfig": "{projectRoot}/.eslintrc.js",
                "lintFilePatterns": ["{projectRoot}/**/*.ts"],
                "ignorePath": "{projectRoot}/.eslintignore",
                "hasTypeAwareRules": true
            }
        }
    }
}
