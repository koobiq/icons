{
    "compilerOptions": {
        "experimentalDecorators": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2022",
        "lib": ["es2022", "dom"],
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist", "icons"]
}
