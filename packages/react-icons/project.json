{
    "name": "@koobiq/react-icons",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "generate": {
            "executor": "nx:run-commands",
            "dependsOn": [
                {
                    "projects": ["@koobiq/icons"],
                    "target": "build"
                }
            ],
            "options": {
                "command": "npx tsx scripts/generate.ts",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{workspaceRoot}/packages/icons/svg/**/*.svg"],
            "outputs": ["{projectRoot}/src/**/*.tsx", "{projectRoot}/src/index.ts"]
        },
        "build": {
            "executor": "nx:run-commands",
            "dependsOn": ["generate"],
            "options": {
                "command": "vite build && tsc -p tsconfig.build.json",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{projectRoot}/src/**/*.tsx", "{projectRoot}/src/index.ts", "{projectRoot}/manifest.json"],
            "outputs": ["{projectRoot}/dist"]
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "options": {
                "eslintConfig": "{projectRoot}/.eslintrc.cjs",
                "lintFilePatterns": ["{projectRoot}/**/*.{ts,tsx}"],
                "ignorePath": "{projectRoot}/.eslintignore",
                "hasTypeAwareRules": true
            },
            "inputs": [
                "{projectRoot}/src/**/*.tsx",
                "{projectRoot}/scripts/generate.ts",
                "{projectRoot}/.eslintrc.cjs"
            ],
            "outputs": ["{projectRoot}/dist"]
        },
        "nx-release-publish": {
            "dependsOn": ["build"],
            "options": {
                "packageRoot": "{projectRoot}/dist"
            }
        }
    }
}
