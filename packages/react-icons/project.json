{
    "name": "@koobiq/react-icons",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "generate": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tsx scripts/generate.ts",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{workspaceRoot}/packages/icons/svg/**/*.svg"],
            "outputs": ["{projectRoot}/src/**/*.tsx", "{projectRoot}/src/index.ts"]
        },
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vite build && tsc -p tsconfig.build.json",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{projectRoot}/src/**/*.tsx", "{projectRoot}/src/index.ts", "{projectRoot}/manifest.json"],
            "outputs": ["{projectRoot}/dist"]
        }
    }
}
