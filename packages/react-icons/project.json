{
    "name": "@koobiq/react-icons",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "tags": ["icons"],
    "targets": {
        "generate": {
            "executor": "nx:run-commands",
            "dependsOn": [
                {
                    "projects": ["@koobiq/icons"],
                    "target": "build"
                }
            ],
            "options": {
                "command": "npx tsx scripts/generate.ts",
                "cwd": "{projectRoot}"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "options": {
                "eslintConfig": "{projectRoot}/.eslintrc.cjs",
                "lintFilePatterns": ["{projectRoot}/**/*.{ts,tsx}"],
                "ignorePath": "{workspaceRoot}/.eslintignore",
                "hasTypeAwareRules": true
            }
        },
        "build": {
            "dependsOn": ["generate"],
            "executor": "nx:run-commands",
            "options": {
                "commands": ["vite build && tsc -p tsconfig.build.json", "npx tsx scripts/copy-meta-to-dist.ts"],
                "parallel": false,
                "cwd": "{projectRoot}"
            }
        },
        "nx-release-publish": {
            "dependsOn": ["build"],
            "options": {
                "packageRoot": "{workspaceRoot}/dist/packages/react-icons"
            }
        }
    }
}
