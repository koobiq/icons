        "@types/react": "^19.2.7",
        "@vitejs/plugin-react": "^5.0.0",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "tsx": "^4.0.0",
        "vite": "^7.1.0",
        "vite-tsconfig-paths": "^5.1.4"
