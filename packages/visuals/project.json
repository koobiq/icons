{
    "name": "@koobiq/visuals",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "npx tsx scripts/copy-meta-to-dist.ts",
                    "cp -r light ../../dist/packages/visuals/light",
                    "cp -r dark ../../dist/packages/visuals/dark"
                ],
                "cwd": "{projectRoot}"
            },
            "outputs": ["{workspaceRoot}/dist/packages/{projectName}"]
        },
        "nx-release-publish": {
            "executor": "@nx/js:release-publish",
            "dependsOn": ["build"],
            "options": {
                "packageRoot": "{workspaceRoot}/dist/packages/{projectName}"
            }
        }
    }
}
