{
    "name": "@koobiq/visuals",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "mkdir -p dist && cp -r light dist/light && cp -r dark dist/dark",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{projectRoot}/dark/**/*.(png|webp)", "{projectRoot}/light/**/*.(png|webp)"],
            "outputs": ["{projectRoot}/dist"]
        },
        "prepublish": {
            "executor": "nx:run-commands",
            "dependsOn": ["build"],
            "options": {
                "command": "npx tsx scripts/copy-meta-to-dist.ts",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{workspaceRoot}/LICENSE", "{projectRoot}/package.json"],
            "outputs": ["{projectRoot}/dist/LICENSE", "{projectRoot}/dist/package.json"]
        },
        "nx-release-publish": {
            "executor": "@nx/js:release-publish",
            "dependsOn": ["prepublish"],
            "options": {
                "packageRoot": "{projectRoot}/dist"
            }
        }
    }
}
