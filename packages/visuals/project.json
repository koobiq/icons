{
    "name": "@koobiq/visuals",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "npx tsx {projectRoot}/scripts/copy-meta-to-dist.ts",
                    "npx tsx {projectRoot}/scripts/convert.ts",
                    "npx tsx {projectRoot}/scripts/generate-preview.ts"
                ],
                "parallel": false,
                "cwd": "{workspaceRoot}"
            }
        },
        "nx-release-publish": {
            "executor": "@nx/js:release-publish",
            "dependsOn": ["build"],
            "options": {
                "packageRoot": "{workspaceRoot}/dist/packages/visuals"
            }
        }
    }
}
