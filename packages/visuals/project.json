{
    "name": "@koobiq/visuals",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "mkdir -p ../../dist/packages/visuals && cp -r light ../../dist/packages/visuals/light && cp -r dark ../../dist/packages/visuals/dark",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{projectRoot}/dark/**/*.(png|webp)", "{projectRoot}/light/**/*.(png|webp)"],
            "outputs": ["{workspaceRoot}/dist/packages/{projectName}"]
        },
        "prepublish": {
            "executor": "nx:run-commands",
            "dependsOn": ["build"],
            "options": {
                "command": "npx tsx scripts/copy-meta-to-dist.ts",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{workspaceRoot}/LICENSE", "{projectRoot}/package.json"],
            "outputs": [
                "{workspaceRoot}/dist/packages/{projectName}/LICENSE",
                "{workspaceRoot}/dist/packages/{projectName}/package.json"
            ]
        },
        "nx-release-publish": {
            "executor": "@nx/js:release-publish",
            "dependsOn": ["prepublish"],
            "options": {
                "packageRoot": "{workspaceRoot}/dist/packages/{projectName}"
            }
        }
    }
}
