{{> fontFace }}

@layer kbq-icons {

{{> selector }}

/*---------------------
*  Icons
*-------------------*/

{{# each codepoints }}
    .{{ ../prefix }}-{{ @key }} {
        font-size: {{ splitFontSize @key }}px;
        &:before {
            content: "\\{{ codepoint this }}";
        }
    }
{{/ each }}

}
