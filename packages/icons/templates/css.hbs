{{> fontFace }}

{{> selector }}

/*---------------------
*  Icons
*-------------------*/

{{# each codepoints }}
    .{{ ../prefix }}-{{ @key }} {
        font-size: {{ splitFontSize @key }}px;
    }
    .{{ ../prefix }}-{{ @key }}:before {
        content: "\\{{ codepoint this }}";
    }
{{/ each }}
