{
    "name": "@koobiq/icons",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "figma:export-icons": {
            "executor": "nx:run-commands",
            "cache": false,
            "options": {
                "command": "figma-export use-config .figmaexportrc.mjs",
                "cwd": "{workspaceRoot}"
            }
        },
        "figma:sync": {
            "executor": "nx:run-commands",
            "cache": false,
            "dependsOn": ["figma:export-icons"],
            "options": {
                "command": "node scripts/svg-copy-to-src.mjs",
                "cwd": "{projectRoot}"
            }
        },
        "build:sprite": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node svg-sprite.js",
                "cwd": "{projectRoot}"
            }
        },
        "build:fonts": {
            "executor": "nx:run-commands",
            "cache": false,
            "options": {
                "command": "fantasticon --config .fantasticonrc.js && node scripts/generate-versioned-font.js",
                "cwd": "{projectRoot}"
            }
        },
        "build:types": {
            "executor": "nx:run-commands",
            "options": {
                "command": "json2ts ../../schema.json ../../dist/packages/icons/types/icons.d.ts",
                "cwd": "{projectRoot}"
            }
        },
        "build": {
            "executor": "nx:run-commands",
            "dependsOn": ["build:sprite", "build:fonts", "build:types"],
            "options": {
                "command": "echo 'build complete'",
                "cwd": "{projectRoot}"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "options": {
                "eslintConfig": "{workspaceRoot}/.eslintrc.js",
                "lintFilePatterns": ["{projectRoot}/**/*.{js,mjs}"],
                "ignorePath": "{workspaceRoot}/.eslintignore"
            }
        },
        "prepublish": {
            "executor": "nx:run-commands",
            "dependsOn": ["build"],
            "options": {
                "command": "node scripts/copy-meta-to-dist.mjs",
                "cwd": "{projectRoot}"
            },
            "outputs": ["{workspaceRoot}/dist/packages/{projectName}"]
        },
        "nx-release-publish": {
            "dependsOn": ["prepublish"],
            "options": {
                "packageRoot": "{workspaceRoot}/dist/packages/{projectName}"
            }
        }
    }
}
