{
    "name": "@koobiq/icons",
    "$schema": "../../node_modules/nx/schemas/project.schema.json",
    "targets": {
        "figma:export-icons": {
            "executor": "nx:run-commands",
            "cache": false,
            "options": {
                "command": "figma-export use-config .figmaexportrc.mjs",
                "cwd": "{workspaceRoot}"
            },
            "outputs": ["{workspaceRoot}/temp/svg"]
        },
        "figma:sync": {
            "executor": "nx:run-commands",
            "cache": false,
            "dependsOn": ["figma:export-icons"],
            "options": {
                "command": "node scripts/svg-copy-to-src.mjs",
                "cwd": "{projectRoot}"
            },
            "outputs": ["{projectRoot}/svg"]
        },
        "build:sprite": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node svg-sprite.js",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{projectRoot}/svg/**/*.svg", "{workspaceRoot}/mapping.json"],
            "outputs": ["{projectRoot}/dist/symbol"]
        },
        "build:fonts": {
            "executor": "nx:run-commands",
            "cache": false,
            "options": {
                "command": "fantasticon --config .fantasticonrc.js && node scripts/generate-versioned-font.js",
                "cwd": "{projectRoot}"
            },
            "inputs": [
                "{projectRoot}/svg/**/*.svg",
                "{workspaceRoot}/mapping.json",
                "{workspaceRoot}/mapping-interop.json"
            ],
            "outputs": ["{projectRoot}/dist/fonts"]
        },
        "build:types": {
            "executor": "nx:run-commands",
            "options": {
                "command": "json2ts ../../schema.json dist/types/icons.d.ts",
                "cwd": "{projectRoot}"
            },
            "inputs": ["{workspaceRoot}/schema.json", "{workspaceRoot}/mapping.json"],
            "outputs": ["{projectRoot}/dist/types/icons.d.ts"]
        },
        "build": {
            "executor": "nx:run-commands",
            "dependsOn": ["build:sprite", "build:fonts", "build:types"],
            "options": {
                "command": "node scripts/copy-meta-to-dist.mjs",
                "cwd": "{projectRoot}"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "options": {
                "eslintConfig": "{projectRoot}/.eslintrc.js",
                "lintFilePatterns": ["{projectRoot}/**/*.{js,mjs}"],
                "ignorePath": "{projectRoot}/.eslintignore"
            }
        },
        "nx-release-publish": {
            "dependsOn": ["build"],
            "options": {
                "packageRoot": "{projectRoot}/dist"
            }
        }
    }
}
